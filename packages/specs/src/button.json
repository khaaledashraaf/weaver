{
  "name": "Button",
  "description": "Primary interactive element for triggering actions. Supports multiple visual styles, sizes, and optional leading/trailing icons.",

  "base": {
    "display": "inline-flex",
    "alignItems": "center",
    "justifyContent": "center",
    "fontWeight": 500,
    "cursor": "pointer",
    "flexShrink": 0,
    "transition": "background-color 150ms ease, color 150ms ease, border-color 150ms ease, box-shadow 150ms ease"
  },

  "variants": {
    "primary": {
      "bg": "{alias.interactive-brand-default}",
      "text": "{alias.content-on-color}",
      "hover": { "bg": "{alias.interactive-brand-hover}" },
      "active": { "bg": "{alias.interactive-brand-pressed}" }
    },
    "secondary": {
      "bg": "{alias.interactive-secondary-default}",
      "text": "{alias.content-default}",
      "border": { "width": "1px", "color": "{alias.border-default}" },
      "shadow": "{shadow.xs}",
      "hover": { "bg": "{alias.interactive-secondary-hover}" },
      "active": { "bg": "{alias.interactive-secondary-pressed}" }
    },
    "soft": {
      "bg": "{alias.interactive-soft-default}",
      "text": "{alias.content-brand-default}",
      "hover": { "bg": "{alias.interactive-soft-hover}" },
      "active": { "bg": "{alias.interactive-soft-pressed}" }
    },
    "outline": {
      "bg": "transparent",
      "text": "{alias.content-default}",
      "border": { "width": "1px", "color": "{alias.border-default}" },
      "hover": { "bg": "{alias.interactive-outlined-hover}" },
      "active": { "bg": "{alias.interactive-outlined-pressed}" }
    },
    "ghost": {
      "bg": "transparent",
      "text": "{alias.content-default}",
      "hover": { "bg": "{alias.interactive-ghost-hover}" },
      "active": { "bg": "{alias.interactive-ghost-pressed}" }
    },
    "danger": {
      "bg": "{alias.interactive-danger-default}",
      "text": "{alias.content-on-color}",
      "hover": { "bg": "{alias.interactive-danger-hover}" },
      "active": { "bg": "{alias.interactive-danger-pressed}" }
    },
    "ghost-primary": {
      "bg": "transparent",
      "text": "{alias.content-brand-default}",
      "hover": { "bg": "{alias.interactive-ghost-hover}" },
      "active": { "bg": "{alias.interactive-ghost-pressed}" }
    },
    "soft-danger": {
      "bg": "{alias.interactive-danger-soft-default}",
      "text": "{alias.content-danger-default}",
      "hover": { "bg": "{alias.interactive-danger-soft-hover}" },
      "active": { "bg": "{alias.interactive-danger-soft-pressed}" }
    },
    "white": {
      "bg": "{alias.interactive-white-default}",
      "text": "{alias.content-default}",
      "border": { "width": "1px", "color": "{alias.border-default}" },
      "shadow": "{shadow.xs}",
      "hover": { "bg": "{alias.interactive-white-hover}" },
      "active": { "bg": "{alias.interactive-white-pressed}" }
    },
    "dashed": {
      "bg": "transparent",
      "text": "{alias.content-default}",
      "border": { "width": "1px", "style": "dashed", "color": "{alias.border-default}" },
      "hover": { "bg": "{alias.interactive-outlined-hover}" },
      "active": { "bg": "{alias.interactive-outlined-pressed}" }
    }
  },

  "sizes": {
    "lg": { "height": "48px", "paddingX": "{spacing.xl}", "gap": "8px", "fontSize": "16px", "borderRadius": "{radius.md}" },
    "md": { "height": "40px", "paddingX": "{spacing.lg}", "gap": "6px", "fontSize": "14px", "borderRadius": "{radius.md}" },
    "sm": { "height": "36px", "paddingX": "{spacing.md}", "gap": "4px", "fontSize": "14px", "borderRadius": "{radius.sm}" },
    "xs": { "height": "32px", "paddingX": "{spacing.md}", "gap": "4px", "fontSize": "13px", "borderRadius": "{radius.sm}" }
  },

  "states": {
    "disabled": { "opacity": 0.4, "pointerEvents": "none", "cursor": "not-allowed" },
    "focus": { "outline": "none", "ring": "2px", "ringColor": "{alias.border-focus}", "ringOffset": "2px" },
    "error": {}
  },

  "compoundVariants": [],

  "props": {
    "variant": { "type": "enum", "values": ["primary", "secondary", "soft", "outline", "ghost", "danger", "ghost-primary", "soft-danger", "white", "dashed"], "default": "primary" },
    "size": { "type": "enum", "values": ["lg", "md", "sm", "xs"], "default": "md" },
    "label": { "type": "string", "description": "Button text content." },
    "leadingIcon": { "type": "string", "description": "Icon name for leading position." },
    "trailingIcon": { "type": "string", "description": "Icon name for trailing position." },
    "showLeadingIcon": { "type": "boolean", "default": false },
    "showTrailingIcon": { "type": "boolean", "default": false },
    "disabled": { "type": "boolean", "default": false },
    "asChild": { "type": "boolean", "default": false, "description": "Render as child element for polymorphic usage." }
  },

  "slots": {
    "label": {
      "element": "Text",
      "description": "Button label text."
    },
    "leadingIcon": {
      "position": "start",
      "element": "Icon",
      "iconSizeByButtonSize": { "lg": "lg", "md": "md", "sm": "md", "xs": "sm" }
    },
    "trailingIcon": {
      "position": "end",
      "element": "Icon",
      "iconSizeByButtonSize": { "lg": "lg", "md": "md", "sm": "md", "xs": "sm" }
    }
  },

  "defaults": { "variant": "primary", "size": "md" },

  "accessibility": {
    "role": "button",
    "notes": "When label is absent, aria-label is required. Disabled buttons should use aria-disabled rather than removing from tab order."
  }
}
