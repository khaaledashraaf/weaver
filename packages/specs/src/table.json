{
  "name": "Table",
  "description": "Data table component supporting sortable columns, selectable rows, and various cell content types including avatars, badges, and actions.",

  "base": {
    "display": "table",
    "width": "100%",
    "borderCollapse": "collapse",
    "fontSize": "14px",
    "lineHeight": "20px"
  },

  "variants": {
    "default": {
      "bg": "{alias.bg-default}",
      "text": "{alias.content-default}",
      "headerBg": "{alias.interactive-table-header}",
      "headerText": "{alias.content-subtle}",
      "borderBottom": { "width": "1px", "color": "{alias.border-subtle}" }
    }
  },

  "sizes": {
    "lg": { "rowMinHeight": "56px", "cellPaddingX": "{spacing.md}", "fontSize": "14px" },
    "sm": { "rowMinHeight": "48px", "cellPaddingX": "{spacing.md}", "fontSize": "14px" }
  },

  "states": {
    "disabled": { "opacity": 0.4, "pointerEvents": "none" },
    "focus": { "outline": "none", "ring": "2px", "ringColor": "{alias.border-focus}" }
  },

  "compoundVariants": [
    {
      "when": { "rowState": "hover" },
      "apply": { "rowBg": "{alias.interactive-ghost-hover}" }
    },
    {
      "when": { "rowState": "selected" },
      "apply": { "rowBg": "{alias.interactive-ghost-hover}" }
    }
  ],

  "props": {
    "size": { "type": "enum", "values": ["lg", "sm"], "default": "lg" },
    "selectable": { "type": "boolean", "default": false, "description": "Enable row selection via checkboxes." },
    "sortable": { "type": "boolean", "default": false, "description": "Enable column sorting." },
    "striped": { "type": "boolean", "default": false, "description": "Alternate row background colors." },
    "data": { "type": "array", "description": "Table data rows." },
    "columns": { "type": "array", "description": "Column definitions with key, label, width, and render config." }
  },

  "slots": {
    "header": {
      "element": "thead",
      "description": "Table header row."
    },
    "headerCell": {
      "element": "th",
      "description": "Individual header cell with sort controls."
    },
    "body": {
      "element": "tbody",
      "description": "Table body containing data rows."
    },
    "row": {
      "element": "tr",
      "description": "Individual table row."
    },
    "cell": {
      "element": "td",
      "description": "Individual table cell."
    },
    "checkbox": {
      "element": "Checkbox",
      "description": "Selection checkbox in the first column."
    },
    "avatar": {
      "element": "Avatar",
      "description": "Avatar cell content for user rows."
    },
    "badge": {
      "element": "Badge",
      "description": "Badge cell content for status columns."
    },
    "action": {
      "element": "IconButton",
      "description": "Action button cell for row operations."
    },
    "sortIcon": {
      "element": "Icon",
      "description": "Sort direction indicator icon in header cells."
    }
  },

  "defaults": { "size": "lg", "selectable": false, "sortable": false },

  "accessibility": {
    "role": "table",
    "notes": "Use proper thead/tbody/th/td semantics. Sortable columns need aria-sort. Selectable rows need aria-selected. Use caption or aria-label for table description."
  }
}
