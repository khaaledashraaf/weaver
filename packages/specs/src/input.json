{
  "name": "Input",
  "description": "Text input field supporting various layout types including add-ons, tags, dropdowns, and quantity steppers.",

  "base": {
    "display": "flex",
    "alignItems": "center",
    "width": "100%",
    "fontWeight": 400,
    "fontFamily": "inherit",
    "transition": "border-color 150ms ease, box-shadow 150ms ease, background-color 150ms ease"
  },

  "variants": {
    "default": {
      "bg": "{alias.interactive-input-default}",
      "text": "{alias.content-default}",
      "border": { "width": "1px", "color": "{alias.border-input}" },
      "placeholder": "{alias.content-placeholder}"
    },
    "soft": {
      "bg": "{alias.interactive-input-soft}",
      "text": "{alias.content-default}",
      "border": { "width": "1px", "color": "transparent" },
      "placeholder": "{alias.content-placeholder}"
    }
  },

  "sizes": {
    "lg": { "height": "48px", "paddingX": "{spacing.lg}", "gap": "8px", "fontSize": "16px", "borderRadius": "{radius.md}" },
    "md": { "height": "40px", "paddingX": "{spacing.md}", "gap": "6px", "fontSize": "14px", "borderRadius": "{radius.md}" }
  },

  "states": {
    "disabled": { "bg": "{alias.interactive-input-disabled}", "opacity": 0.5, "pointerEvents": "none", "cursor": "not-allowed" },
    "focus": { "borderColor": "{alias.border-focus}", "ring": "2px", "ringColor": "{alias.border-focus}", "ringOffset": "0px" },
    "error": { "borderColor": "{alias.border-focus-danger}", "ring": "2px", "ringColor": "{alias.border-focus-danger}" }
  },

  "compoundVariants": [
    {
      "when": { "type": "add-on" },
      "apply": { "borderRadius": "0 {radius.md} {radius.md} 0" }
    },
    {
      "when": { "type": "inline-add-on" },
      "apply": {}
    },
    {
      "when": { "type": "quantity" },
      "apply": { "textAlign": "center" }
    },
    {
      "when": { "style": "soft", "state": "focus" },
      "apply": { "borderColor": "{alias.border-focus}" }
    }
  ],

  "props": {
    "type": { "type": "enum", "values": ["default", "shortcut", "add-on", "inline-add-on", "tags", "inline-tags", "trailing-dropdown", "leading-dropdown", "quantity", "trailing-button", "leading-button"], "default": "default" },
    "style": { "type": "enum", "values": ["default", "soft"], "default": "default" },
    "size": { "type": "enum", "values": ["lg", "md"], "default": "md" },
    "placeholder": { "type": "string", "description": "Placeholder text shown when input is empty." },
    "value": { "type": "string", "description": "Controlled input value." },
    "disabled": { "type": "boolean", "default": false },
    "error": { "type": "boolean", "default": false, "description": "Show error state with danger border." },
    "label": { "type": "string", "description": "Associated label text." },
    "helperText": { "type": "string", "description": "Helper or error message below the input." },
    "leadingIcon": { "type": "string", "description": "Icon name for the leading slot." },
    "trailingIcon": { "type": "string", "description": "Icon name for the trailing slot." }
  },

  "slots": {
    "input": {
      "element": "input",
      "description": "The native input element."
    },
    "leadingIcon": {
      "position": "start",
      "element": "Icon",
      "description": "Icon rendered before the input text."
    },
    "trailingIcon": {
      "position": "end",
      "element": "Icon",
      "description": "Icon rendered after the input text."
    },
    "addOn": {
      "position": "start",
      "element": "Text",
      "description": "Static text or select add-on prepended to the input."
    },
    "label": {
      "element": "Label",
      "description": "Form label for the input."
    },
    "helperText": {
      "element": "Text",
      "description": "Helper or error text below the input."
    }
  },

  "defaults": { "type": "default", "style": "default", "size": "md" },

  "accessibility": {
    "role": "textbox",
    "notes": "Always associate a label via htmlFor/id. Error state should set aria-invalid=true and link to helper text via aria-describedby."
  }
}
